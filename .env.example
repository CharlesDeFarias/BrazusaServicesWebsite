# Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Airtable (https://airtable.com/create/tokens)
AIRTABLE_API_TOKEN=patXXXXXXXXXXXXXX

# Google Sheets — base64-encoded service account JSON
# Generate: base64 -i ~/Downloads/your-service-account.json
GOOGLE_SERVICE_ACCOUNT_KEY=

# Brazusa Cleaning client config
BRAZUSA_CLEANING_NOTIFICATION_EMAIL=cddefari@gmail.com
BRAZUSA_CLEANING_AIRTABLE_BASE_ID=appXXXXXXXXXX
BRAZUSA_CLEANING_SHEET_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Ops layer (hidden /ops app for the internal team)
OPS_SESSION_SECRET=          # random hex string; signs session cookies
OPS_PASSCODES=               # "name:code,name:code" per-person passcodes
BRAZUSA_OPS_AIRTABLE_TOKEN=  # SCOPED read-only token for the ops base (never the form-handler token)
BRAZUSA_OPS_AIRTABLE_BASE_ID=
OPS_PAYROLL_SHEET_ID=        # private Google Sheet the local payroll engine pushes into
OPS_INVOICE_PAYMENT_LINES=  # JSON array of payment-method lines shown on printable invoices
